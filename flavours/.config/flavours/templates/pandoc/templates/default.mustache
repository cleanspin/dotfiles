/* Base16 {{scheme-name}} - Pandoc HTML Theme */
/* Generated by Flavours */

:root {
  --base00: #{{base00-hex}};
  --base01: #{{base01-hex}};
  --base02: #{{base02-hex}};
  --base03: #{{base03-hex}};
  --base04: #{{base04-hex}};
  --base05: #{{base05-hex}};
  --base06: #{{base06-hex}};
  --base07: #{{base07-hex}};
  --base08: #{{base08-hex}};
  --base09: #{{base09-hex}};
  --base0A: #{{base0A-hex}};
  --base0B: #{{base0B-hex}};
  --base0C: #{{base0C-hex}};
  --base0D: #{{base0D-hex}};
  --base0E: #{{base0E-hex}};
  --base0F: #{{base0F-hex}};
}

* {
  box-sizing: border-box;
}

html {
  font-size: 16px;
}

body {
  background: var(--base00);
  color: var(--base05);
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
  line-height: 1.7;
  max-width: 800px;
  margin: 0 auto;
  padding: 2rem;
}

/* Headings */
h1, h2, h3, h4, h5, h6 {
  color: var(--base0D);
  margin-top: 1.5em;
  margin-bottom: 0.5em;
  font-weight: 600;
  line-height: 1.3;
}

h1 { font-size: 2.2rem; border-bottom: 2px solid var(--base02); padding-bottom: 0.3em; }
h2 { font-size: 1.8rem; border-bottom: 1px solid var(--base02); padding-bottom: 0.2em; }
h3 { font-size: 1.4rem; }
h4 { font-size: 1.2rem; }
h5 { font-size: 1rem; }
h6 { font-size: 0.9rem; color: var(--base04); }

/* Links */
a {
  color: var(--base0E);
  text-decoration: none;
}
a:hover {
  color: var(--base0C);
  text-decoration: underline;
}

/* Paragraphs */
p {
  margin: 1em 0;
}

/* Lists */
ul, ol {
  padding-left: 2em;
  margin: 1em 0;
}

li {
  margin: 0.3em 0;
}

/* Inline code */
code {
  background: var(--base01);
  color: var(--base08);
  padding: 0.2em 0.4em;
  border-radius: 4px;
  font-family: "JetBrains Mono", "Fira Code", "SF Mono", Consolas, monospace;
  font-size: 0.9em;
}

/* Code blocks */
pre {
  background: var(--base01);
  padding: 1rem;
  border-radius: 8px;
  overflow-x: auto;
  border-left: 4px solid var(--base0D);
  margin: 1.5em 0;
}

pre code {
  background: none;
  padding: 0;
  color: var(--base05);
  font-size: 0.875rem;
  line-height: 1.5;
}

/* Syntax highlighting classes (pandoc generates these) */
.kw { color: var(--base0E); font-weight: bold; }  /* Keyword */
.dt { color: var(--base0A); }                      /* DataType */
.dv { color: var(--base09); }                      /* DecVal */
.bn { color: var(--base09); }                      /* BaseN */
.fl { color: var(--base09); }                      /* Float */
.ch { color: var(--base0B); }                      /* Char */
.st { color: var(--base0B); }                      /* String */
.co { color: var(--base03); font-style: italic; }  /* Comment */
.ot { color: var(--base0C); }                      /* Other */
.al { color: var(--base08); font-weight: bold; }   /* Alert */
.fu { color: var(--base0D); }                      /* Function */
.er { color: var(--base08); font-weight: bold; }   /* Error */
.wa { color: var(--base0A); font-weight: bold; }   /* Warning */
.cn { color: var(--base09); }                      /* Constant */
.sc { color: var(--base0F); }                      /* SpecialChar */
.vs { color: var(--base0B); }                      /* VerbatimString */
.ss { color: var(--base0B); }                      /* SpecialString */
.im { color: var(--base0E); }                      /* Import */
.va { color: var(--base08); }                      /* Variable */
.cf { color: var(--base0E); font-weight: bold; }   /* ControlFlow */
.op { color: var(--base05); }                      /* Operator */
.bu { color: var(--base0C); }                      /* BuiltIn */
.ex { color: var(--base0D); }                      /* Extension */
.pp { color: var(--base0A); }                      /* Preprocessor */
.at { color: var(--base0D); }                      /* Attribute */
.do { color: var(--base03); font-style: italic; }  /* Documentation */
.an { color: var(--base0A); font-weight: bold; }   /* Annotation */
.cv { color: var(--base03); font-style: italic; }  /* CommentVar */
.in { color: var(--base03); }                      /* Information */

/* Blockquotes */
blockquote {
  border-left: 4px solid var(--base0E);
  margin: 1.5em 0;
  padding: 0.5em 1em;
  background: var(--base01);
  border-radius: 0 8px 8px 0;
  color: var(--base04);
}

blockquote p {
  margin: 0.5em 0;
}

/* Horizontal rule */
hr {
  border: none;
  border-top: 2px solid var(--base02);
  margin: 2em 0;
}

/* Tables */
table {
  border-collapse: collapse;
  width: 100%;
  margin: 1.5em 0;
  overflow-x: auto;
  display: block;
}

th, td {
  border: 1px solid var(--base02);
  padding: 0.75rem;
  text-align: left;
}

th {
  background: var(--base01);
  color: var(--base0D);
  font-weight: 600;
}

tr:nth-child(even) {
  background: var(--base01);
}

tr:hover {
  background: var(--base02);
}

/* Images */
img {
  max-width: 100%;
  height: auto;
  border-radius: 8px;
  margin: 1em 0;
}

/* Task lists (GitHub-style checkboxes) */
input[type="checkbox"] {
  margin-right: 0.5em;
  accent-color: var(--base0D);
}

/* Definition lists */
dl {
  margin: 1em 0;
}

dt {
  font-weight: bold;
  color: var(--base0D);
  margin-top: 1em;
}

dd {
  margin-left: 2em;
  margin-top: 0.25em;
}

/* Footnotes */
.footnotes {
  margin-top: 3em;
  padding-top: 1em;
  border-top: 1px solid var(--base02);
  font-size: 0.9rem;
}

.footnote-ref {
  color: var(--base0E);
  font-size: 0.8em;
  vertical-align: super;
}

/* Table of contents */
nav#TOC {
  background: var(--base01);
  padding: 1rem;
  border-radius: 8px;
  margin-bottom: 2em;
}

nav#TOC ul {
  list-style: none;
  padding-left: 1em;
}

nav#TOC > ul {
  padding-left: 0;
}

nav#TOC a {
  color: var(--base05);
}

nav#TOC a:hover {
  color: var(--base0E);
}

/* Print styles */
@media print {
  body {
    background: white;
    color: black;
    max-width: none;
  }

  a {
    color: inherit;
    text-decoration: underline;
  }

  pre, blockquote {
    page-break-inside: avoid;
  }

  h1, h2, h3 {
    page-break-after: avoid;
  }
}

/* Responsive */
@media (max-width: 600px) {
  body {
    padding: 1rem;
  }

  h1 { font-size: 1.8rem; }
  h2 { font-size: 1.5rem; }
  h3 { font-size: 1.2rem; }
}
