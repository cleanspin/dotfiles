# Base16 {{scheme-name}} - Mako Theme
# Author: {{scheme-author}}

# Global
max-visible=5
sort=-time
layer=overlay
anchor=center-right
output=HDMI-A-1
group-by=app-name

# Appearance
font=Google Sans Flex 14
background-color=#{{base00-hex}}dd
text-color=#{{base05-hex}}
border-color=#{{base0D-hex}}
border-size=2
border-radius=15
padding=25
margin=20
width=450
height=200

# Icons
icons=1
max-icon-size=64
icon-path=/usr/share/icons/breeze-dark

# Behavior
default-timeout=8000
ignore-timeout=1

# Urgency levels
[urgency=low]
background-color=#{{base00-hex}}cc
border-color=#{{base0C-hex}}

[urgency=normal]
background-color=#{{base00-hex}}dd
border-color=#{{base0D-hex}}

[urgency=critical]
background-color=#{{base00-hex}}ff
border-color=#{{base08-hex}}
default-timeout=0
ignore-timeout=0

[app-name="Google Chrome"]
default-timeout=8000
ignore-timeout=1
