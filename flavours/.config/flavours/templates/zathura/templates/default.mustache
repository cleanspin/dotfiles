# Base16 {{scheme-name}} - Zathura Config
# Generated by Flavours

# Clean, minimal UI
set guioptions ""
set statusbar-basename true
set window-title-basename true
set window-title-home-tilde true
set selection-clipboard clipboard

# Colors
set default-bg                  "#{{base00-hex}}"
set default-fg                  "#{{base05-hex}}"

set statusbar-bg                "#{{base01-hex}}"
set statusbar-fg                "#{{base05-hex}}"

set inputbar-bg                 "#{{base01-hex}}"
set inputbar-fg                 "#{{base05-hex}}"

set notification-bg             "#{{base01-hex}}"
set notification-fg             "#{{base05-hex}}"
set notification-error-bg       "#{{base08-hex}}"
set notification-error-fg       "#{{base00-hex}}"
set notification-warning-bg     "#{{base0A-hex}}"
set notification-warning-fg     "#{{base00-hex}}"

set highlight-color             "#{{base0A-hex}}"
set highlight-active-color      "#{{base0D-hex}}"

set completion-bg               "#{{base01-hex}}"
set completion-fg               "#{{base05-hex}}"
set completion-group-bg         "#{{base01-hex}}"
set completion-group-fg         "#{{base0D-hex}}"
set completion-highlight-bg     "#{{base0D-hex}}"
set completion-highlight-fg     "#{{base00-hex}}"

# Recolor mode (dark mode for documents)
set recolor                     true
set recolor-keephue             true
set recolor-darkcolor           "#{{base05-hex}}"
set recolor-lightcolor          "#{{base00-hex}}"
set recolor-reverse-video       true

# Render loading
set render-loading              true
set render-loading-bg           "#{{base00-hex}}"
set render-loading-fg           "#{{base05-hex}}"

# Keybindings
map <C-r> recolor
map <C-=> zoom in
map <C--> zoom out
map <C-0> zoom 100%
map u scroll half-up
map d scroll half-down
map D toggle_page_mode
map r reload
map R rotate
map K zoom in
map J zoom out
map p print
