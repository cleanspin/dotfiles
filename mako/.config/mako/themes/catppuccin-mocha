# Mako notification daemon - Catppuccin Mocha

# Global
max-visible=5
sort=-time
layer=overlay
anchor=center-right
output=HDMI-A-1

# Appearance
font=Google Sans Flex 14
background-color=#1e1e2edd
text-color=#cdd6f4
border-color=#cba6f7
border-size=2
border-radius=15
padding=25
margin=20
width=450
height=200

# Icons
icons=1
max-icon-size=64
icon-path=/usr/share/icons/Papirus-Dark

# Behavior
default-timeout=5000
ignore-timeout=0

# Urgency levels
[urgency=low]
background-color=#1e1e2ecc
border-color=#89b4fa

[urgency=normal]
background-color=#1e1e2edd
border-color=#cba6f7

[urgency=critical]
background-color=#1e1e2eff
border-color=#f38ba8
default-timeout=0
