# Mako notification daemon - Dracula

# Global
max-visible=5
sort=-time
layer=overlay
anchor=center-right
output=HDMI-A-1

# Appearance
font=Google Sans Flex 14
background-color=#282a36dd
text-color=#f8f8f2
border-color=#bd93f9
border-size=2
border-radius=15
padding=25
margin=20
width=450
height=200

# Icons
icons=1
max-icon-size=64
icon-path=/usr/share/icons/Papirus-Dark

# Behavior
default-timeout=5000
ignore-timeout=0

# Urgency levels
[urgency=low]
background-color=#282a36cc
border-color=#8be9fd

[urgency=normal]
background-color=#282a36dd
border-color=#bd93f9

[urgency=critical]
background-color=#282a36ff
border-color=#ff5555
default-timeout=0
