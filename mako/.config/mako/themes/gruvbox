# Mako notification daemon - Gruvbox

# Global
max-visible=5
sort=-time
layer=overlay
anchor=center-right
output=HDMI-A-1

# Appearance
font=Google Sans Flex 14
background-color=#282828dd
text-color=#ebdbb2
border-color=#fe8019
border-size=2
border-radius=15
padding=25
margin=20
width=450
height=200

# Icons
icons=1
max-icon-size=64
icon-path=/usr/share/icons/Papirus-Dark

# Behavior
default-timeout=5000
ignore-timeout=0

# Urgency levels
[urgency=low]
background-color=#282828cc
border-color=#fabd2f

[urgency=normal]
background-color=#282828dd
border-color=#fe8019

[urgency=critical]
background-color=#282828ff
border-color=#fb4934
default-timeout=0
