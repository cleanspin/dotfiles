# Mako notification daemon - Tokyo Night

# Global
max-visible=5
sort=-time
layer=overlay
anchor=center-right
output=HDMI-A-1

# Appearance
font=Google Sans Flex 14
background-color=#1a1b26dd
text-color=#c0caf5
border-color=#bb9af7
border-size=2
border-radius=15
padding=25
margin=20
width=450
height=200

# Icons
icons=1
max-icon-size=64
icon-path=/usr/share/icons/Papirus-Dark

# Behavior
default-timeout=5000
ignore-timeout=0

# Urgency levels
[urgency=low]
background-color=#1a1b26cc
border-color=#7aa2f7

[urgency=normal]
background-color=#1a1b26dd
border-color=#bb9af7

[urgency=critical]
background-color=#1a1b26ff
border-color=#f7768e
default-timeout=0
