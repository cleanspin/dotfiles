# Mako notification daemon - Rose Pine

# Global
max-visible=5
sort=-time
layer=overlay
anchor=center-right
output=HDMI-A-1

# Appearance
font=Google Sans Flex 14
background-color=#191724dd
text-color=#e0def4
border-color=#c4a7e7
border-size=2
border-radius=15
padding=25
margin=20
width=450
height=200

# Icons
icons=1
max-icon-size=64
icon-path=/usr/share/icons/Papirus-Dark

# Behavior
default-timeout=5000
ignore-timeout=0

# Urgency levels
[urgency=low]
background-color=#191724cc
border-color=#9ccfd8

[urgency=normal]
background-color=#191724dd
border-color=#c4a7e7

[urgency=critical]
background-color=#191724ff
border-color=#eb6f92
default-timeout=0
